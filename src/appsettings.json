{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SphereBlog;Trusted_Connection=true;TrustServerCertificate=true"
  },
  "Jwt": {
    "Secret": "CHANGE-ME-use-dotnet-user-secrets-for-dev-and-env-var-for-prod!!",
    "Issuer": "SphereBlog",
    "Audience": "SphereBlog",
    "ExpirationInHours": 24
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sphere-blog-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithCorrelationId" ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "AllowedHosts": "*"
}
