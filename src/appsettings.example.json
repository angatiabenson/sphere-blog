{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=SphereBlog;Integrated Security=False;User Id=<db-user>;Password=<db-password>;TrustServerCertificate=True;Encrypt=True"
  },
  "Jwt": {
    "Secret": "<min-32-char-random-secret>",
    "Issuer": "SphereBlog",
    "Audience": "SphereBlog",
    "ExpirationInHours": 24
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sphere-blog-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithCorrelationId" ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "AllowedHosts": "*"
}
